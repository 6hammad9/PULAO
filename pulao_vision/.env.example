API_BASE_URL=http://localhost:3000/api
DETECTED_FRAMES_API=http://localhost:3000/api/detectedframes

VISION_HOST=0.0.0.0
VISION_PORT=6033
VISION_HTTPS_PORT=6443
VISION_ENABLE_HTTPS=1
VISION_USE_WAITRESS=1
VISION_REQUIRE_EVENT_CONTEXT=1
VISION_RESTART_DELAY_SECONDS=5

OCR_BASE_DIR=E:/New folder/OCR
OCR_EVENTS_DIR=E:/New folder/OCR/events
WHITELIST_FOLDER=E:/New folder/OCR/whitelisted
USERS_PKL_PATH=E:/New folder/OCR/users.pkl
METADATA_PATH=E:/New folder/OCR/metadata.json
DETECTED_FOLDER=E:/New folder/OCR/detected
YOLO_MODEL_PATH=E:/New folder/OCR/models/yolov5m_dynamic.onnx
GLINTR_MODEL_PATH=E:/New folder/OCR/models/glintr100.onnx
F2_MODEL_PATH=E:/New folder/OCR/models/f2.onnx

CAMERA_POLL_SECONDS=10
VISION_FRAME_SKIP=1
CAMERA_RECONNECT_SECONDS=5
STREAM_JPEG_QUALITY=80
CAMERA_READ_FAIL_LIMIT=30
CAMERA_TEST_TIMEOUT=10
RECOGNITION_THRESHOLD=0.35
PERSON_CONFIDENCE_THRESHOLD=0.80
DETECTION_LOG_INTERVAL_SECONDS=5
MATCH_LOG_INTERVAL_SECONDS=5
EXIT_GRACE_SECONDS=5
TRACK_SWITCH_SECONDS=8
RTSP_TRANSPORT=tcp
NETWORK_OPEN_TIMEOUT_US=8000000
